<aside class="account-sidebar profile-sidebar">
  <div class="profile-user-info">
    <div class="profile-avatar-large"><img src="<%= user.profileImage %>" alt="Profile"></div>
    <div>
      <% if (typeof allowProfileImageEdit !== 'undefined' && allowProfileImageEdit) { %>
        <input type="file" id="fileInput" hidden>
        <label for="fileInput" class="profilePic-btn">Change photo</label>
      <% } %>
      <div class="profile-user-name" id="sidebarName"><%= user.name %></div>
      <div class="profile-user-email" id="sidebarEmail"><%= user.email %></div>
    </div>
  </div>

  <div class="mobile-header-logout">
    <form action="/user/logout" method="POST" data-account-logout-form>
      <button type="submit" class="mobile-header-logout-btn" aria-label="Log out">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
          <polyline points="16 17 21 12 16 7"></polyline>
          <line x1="21" y1="12" x2="9" y2="12"></line>
        </svg>
        Logout
      </button>
    </form>
  </div>

  <div class="account-nav-carousel" data-account-nav>
    <button type="button" class="account-nav-arrow prev" aria-label="Previous section">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>

    <nav class="account-nav-track sidebar-menu">
      <a href="/user/profile" class="sidebar-link <%= activePage === 'profile' ? 'active' : '' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
          <circle cx="12" cy="7" r="4"></circle>
        </svg>
        Profile
      </a>
      <a href="/user/addresses" class="sidebar-link <%= activePage === 'addresses' ? 'active' : '' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
          <circle cx="12" cy="10" r="3"></circle>
        </svg>
        Addresses
      </a>
      <a href="/user/orders" class="sidebar-link <%= activePage === 'orders' ? 'active' : '' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="9" cy="21" r="1"></circle>
          <circle cx="20" cy="21" r="1"></circle>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
        </svg>
        My Orders
      </a>
      <a href="/user/wallet" class="sidebar-link <%= activePage === 'wallet' ? 'active' : '' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="2" y="5" width="20" height="14" rx="2" />
          <line x1="2" y1="10" x2="22" y2="10" />
        </svg>
        Wallet
      </a>
      <a href="/user/referral" class="sidebar-link <%= activePage === 'referral' ? 'active' : '' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
          <circle cx="9" cy="7" r="4"></circle>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
          <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
        </svg>
        Refer & Earn
      </a>
    <form action="/user/logout" method="POST" style="display: inline" data-account-logout-form>
      <button type="submit" class="sidebar-link logout-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
            <polyline points="16 17 21 12 16 7"></polyline>
            <line x1="21" y1="12" x2="9" y2="12"></line>
          </svg>
          Log Out
        </button>
      </form>
    </nav>

    <button type="button" class="account-nav-arrow next" aria-label="Next section">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  </div>
</aside>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const carousels = document.querySelectorAll("[data-account-nav]");
    const logoutForms = document.querySelectorAll("[data-account-logout-form]");

    logoutForms.forEach((logoutForm) => {
      logoutForm.addEventListener("submit", async (e) => {
        e.preventDefault();

        if (typeof Swal !== "undefined") {
          const result = await Swal.fire({
            title: "Log out?",
            text: "You'll need to sign in again to access your account.",
            icon: "warning",
            showCancelButton: true,
            confirmButtonText: "Logout",
            cancelButtonText: "Stay here",
            confirmButtonColor: "#dc2626",
            cancelButtonColor: "#94a3b8",
          });

          if (result.isConfirmed) {
            logoutForm.submit();
          }
          return;
        }

        if (window.confirm("Log out of your account?")) {
          logoutForm.submit();
        }
      });
    });

    carousels.forEach((carousel) => {
      const track = carousel.querySelector(".account-nav-track");
      const prevBtn = carousel.querySelector(".account-nav-arrow.prev");
      const nextBtn = carousel.querySelector(".account-nav-arrow.next");
      const sectionLinks = Array.from(track.querySelectorAll('a.sidebar-link[href]'));

      if (!track || !prevBtn || !nextBtn) return;

      const getActiveIndex = () => sectionLinks.findIndex((link) => link.classList.contains("active"));

      const updateArrowState = () => {
        const activeIndex = getActiveIndex();
        const hasPrevPage = activeIndex > 0;
        const hasNextPage = activeIndex >= 0 && activeIndex < sectionLinks.length - 1;

        prevBtn.disabled = !hasPrevPage;
        nextBtn.disabled = !hasNextPage;
      };

      prevBtn.addEventListener("click", () => {
        const activeIndex = getActiveIndex();
        if (activeIndex > 0) {
          window.location.href = sectionLinks[activeIndex - 1].href;
        }
      });

      nextBtn.addEventListener("click", () => {
        const activeIndex = getActiveIndex();
        if (activeIndex >= 0 && activeIndex < sectionLinks.length - 1) {
          window.location.href = sectionLinks[activeIndex + 1].href;
        }
      });

      window.addEventListener("resize", updateArrowState);
      requestAnimationFrame(updateArrowState);
    });
  });
</script>
