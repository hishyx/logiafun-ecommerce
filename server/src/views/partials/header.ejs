<style>
  .login-header-btn {
    display: flex;
    align-items: center;
    padding: 0.5rem 1.25rem;
    background-color: #0f172a;
    color: white !important;
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.9rem;
    transition: all 0.3s ease;
    text-decoration: none;
    border: none;
  }

  .login-header-btn:hover {
    background-color: #1e293b;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(15, 23, 42, 0.15);
  }

  .login-header-btn svg {
    transition: transform 0.3s ease;
  }

  .login-header-btn:hover svg {
    transform: translateX(2px);
  }

  .guest-signin-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  .guest-signin-hint {
    position: absolute;
    right: 0;
    top: calc(100% + 0.55rem);
    padding: 0.55rem 0.8rem;
    border-radius: 12px;
    background: #0f172a;
    color: #ffffff;
    font-size: 0.78rem;
    line-height: 1.2;
    white-space: nowrap;
    box-shadow: 0 16px 30px rgba(15, 23, 42, 0.18);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
    z-index: 30;
  }

  .guest-signin-hint::before {
    content: "";
    position: absolute;
    top: -6px;
    right: 22px;
    width: 12px;
    height: 12px;
    background: #0f172a;
    transform: rotate(45deg);
  }

  .guest-signin-wrap:hover .guest-signin-hint,
  .guest-signin-wrap:focus-within .guest-signin-hint {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .guest-signin-hint {
      right: auto;
      left: 0;
    }

    .guest-signin-hint::before {
      right: auto;
      left: 22px;
    }
  }

  .toastify.app-toast {
    position: fixed;
    top: 18px;
    right: 16px;
    left: auto !important;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    width: auto;
    max-width: min(380px, calc(100vw - 32px));
    min-height: 58px;
    padding: 14px 16px !important;
    border-radius: 18px !important;
    border: 1px solid rgba(255, 255, 255, 0.2);
    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.2) !important;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    z-index: 9999;
  }

  .toastify.app-toast.on {
    opacity: 1;
  }

  .toastify.app-toast .toast-close {
    margin-left: auto;
    width: 28px;
    height: 28px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    color: rgba(255, 255, 255, 0.92);
    background: rgba(255, 255, 255, 0.14);
    border: 1px solid rgba(255, 255, 255, 0.16);
    font-size: 18px;
    line-height: 1;
    opacity: 1;
    cursor: pointer;
    pointer-events: auto;
    user-select: none;
    flex-shrink: 0;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .toastify.app-toast .toast-close:hover {
    background: rgba(255, 255, 255, 0.24);
    transform: scale(1.05);
  }

  .toastify.app-toast-success {
    background: linear-gradient(135deg, #059669 0%, #22c55e 100%) !important;
  }

  .toastify.app-toast-error {
    background: linear-gradient(135deg, #dc2626 0%, #f97316 100%) !important;
  }

  .toastify.app-toast-info {
    background: linear-gradient(135deg, #2563eb 0%, #06b6d4 100%) !important;
  }

  @media (max-width: 576px) {
    .toastify.app-toast {
      right: 12px;
      max-width: calc(100vw - 24px);
      min-height: 52px;
      padding: 12px 14px !important;
      border-radius: 14px !important;
    }
  }
</style>

<header class="header">
  <div class="container">
    <div class="header-content">
      <a href="/home" class="logo">
        <span class="full-logo">logia<span>Fun</span></span>
        <span class="mobile-logo"><span class="l">l</span><span class="f">F</span></span>
      </a>

      <nav class="nav">
        <a href="/home">Home</a>
        <a href="/products">Shop</a>
        <!-- <a href="/pages">Pages</a>
        <a href="/blog">Blog</a>
        <a href="/contact">Contact</a> -->
      </nav>

      <div class="header-right">
        <div class="header-icons-group">
          <button type="button" class="mobile-search-toggle" id="mobileSearchToggle" aria-label="Open search">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8" />
              <path d="m21 21-4.35-4.35" />
            </svg>
          </button>

          <div class="search-box">
            <label for="searchBox" style="cursor: pointer; display: flex; align-items: center;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8" />
                <path d="m21 21-4.35-4.35" />
              </svg>
            </label>

            <input type="text" placeholder="Search" id="searchBox"
              value="<%= typeof searchValue !== 'undefined' ? searchValue : '' %>" />


            <!-- Cancel Button -->
            <button type="button" class="clear-search" id="clearSearchBtn">
              ✕
            </button>

            <button type="button" class="mobile-search-close" id="mobileSearchClose" aria-label="Close search">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            </button>
          </div>


          <% if (locals.user) { %>
            <a href="/user/profile" class="profile-btn" title="Go to Profile">
              <div class="profile-icon">
                <img src="<%=user.profileImage%>" style="border-radius: 30px;border-color: black;border-width: 1px;">
              </div>

              <span class="profile-name">
                <%= user.name %>
              </span>
            </a>
            <% } else { %>
              <div class="guest-signin-wrap">
                <a href="/auth/login" class="login-header-btn guest-profile-link" title="Click here to sign in">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 21a8 8 0 0 0-16 0"></path>
                    <circle cx="12" cy="8" r="5"></circle>
                  </svg>
                  <span class="login-header-text">Sign in</span>
                </a>
                <span class="guest-signin-hint">Click here to sign in <span class="guest-signin-arrow">→</span></span>
              </div>
              <% } %>

                <a href="/user/wishlist" class="cart-icon" style="margin-right: 15px;">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path
                      d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z">
                    </path>
                  </svg>
                  <span class="cart-badge">
                    <%=wishlistCount%>
                  </span>
                </a>

                <a href="/user/cart" class="cart-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="9" cy="21" r="1" />
                    <circle cx="20" cy="21" r="1" />
                    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
                  </svg>
                  <span class="cart-badge">
                    <%=cartCount%>
                  </span>
                </a>
        </div>

        <button class="menu-toggle" aria-label="Toggle menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </div>
  </div>
</header>

<script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
<script>
  window.showToast = function (message, type = 'success') {
    let toastClass = 'app-toast app-toast-success';
    if (type === 'error') {
      toastClass = 'app-toast app-toast-error';
    } else if (type === 'info') {
      toastClass = 'app-toast app-toast-info';
    }

    Toastify({
      text: message,
      className: toastClass,
      duration: 3000,
      close: true,
      gravity: "top",
      position: "right",
      offset: {
        x: 16,
        y: 18
      },
      stopOnFocus: true,
      style: {
        borderRadius: "8px",
        boxShadow: "0 4px 12px rgba(0,0,0,0.15)",
        padding: "12px 16px",
        fontSize: "14px",
        fontWeight: "500",
        width: "fit-content",
        maxWidth: "min(380px, calc(100vw - 32px))"
      }
    }).showToast();
  };

  // Mobile navigation toggle
  document.addEventListener('DOMContentLoaded', () => {
    const header = document.querySelector('.header');
    const menuToggle = document.querySelector('.menu-toggle');
    const nav = document.querySelector('.nav');
    const mobileSearchToggle = document.getElementById('mobileSearchToggle');
    const mobileSearchClose = document.getElementById('mobileSearchClose');
    const searchInput = document.getElementById('searchBox');

    if (menuToggle && nav) {
      menuToggle.addEventListener('click', () => {
        header?.classList.remove('mobile-search-open');
        nav.classList.toggle('nav-active');
        menuToggle.classList.toggle('active');
      });
    }

    if (mobileSearchToggle && header && searchInput) {
      mobileSearchToggle.addEventListener('click', () => {
        header.classList.add('mobile-search-open');
        nav?.classList.remove('nav-active');
        menuToggle?.classList.remove('active');
        setTimeout(() => searchInput.focus(), 50);
      });
    }

    if (mobileSearchClose && header) {
      mobileSearchClose.addEventListener('click', () => {
        header.classList.remove('mobile-search-open');
      });
    }

    window.addEventListener('resize', () => {
      if (window.innerWidth > 768) {
        header?.classList.remove('mobile-search-open');
      }
    });
  });
</script>
<script src="/js/helpers/user.search.js"></script>
