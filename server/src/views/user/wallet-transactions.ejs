<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Transaction History - logiaFun</title>
    <link rel="stylesheet" href="/css/home.css" />
    <style>
        .transactions-page-wrapper {
            max-width: 900px;
            margin: 2rem auto;
            padding: 0 1rem;
            min-height: 60vh;
        }

        .page-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 2rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid #e2e8f0;
        }

        .page-header h2 {
            font-size: 1.75rem;
            color: var(--text-dark, #0f172a);
            margin: 0;
        }

        .back-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 1rem;
            background: var(--white, #fff);
            border: 1px solid #e2e8f0;
            border-radius: var(--radius-md, 8px);
            color: var(--text-dark, #0f172a);
            text-decoration: none;
            font-weight: 500;
            transition: all 0.2s ease;
        }

        .back-btn:hover {
            background: #f8fafc;
            border-color: #cbd5e1;
            color: var(--primary, #2563eb);
        }

        /* Reusing Wallet Specific Styles */
        .transaction-list {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .transaction-card {
            background: var(--white, #fff);
            border: 1px solid #e2e8f0;
            border-radius: var(--radius-lg, 12px);
            padding: 1.25rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            transition: var(--transition, all 0.3s ease);
        }

        .transaction-card:hover {
            border-color: #cbd5e1;
            box-shadow: var(--shadow-sm, 0 1px 2px 0 rgba(0, 0, 0, 0.05));
        }

        .tx-left {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .tx-icon {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .tx-icon.credit {
            background: #ecfdf5;
            color: #10b981;
        }

        .tx-icon.debit {
            background: #fef2f2;
            color: #ef4444;
        }

        .tx-details h4 {
            font-weight: 600;
            color: var(--text-dark, #0f172a);
            margin-bottom: 0.25rem;
            font-size: 1rem;
            margin-top: 0;
        }

        .tx-date {
            color: var(--text-light, #64748b);
            font-size: 0.85rem;
        }

        .tx-right {
            text-align: right;
        }

        .tx-amount {
            font-weight: 700;
            font-size: 1.1rem;
            margin-bottom: 0.25rem;
        }

        .tx-amount.credit {
            color: #10b981;
        }

        .tx-amount.debit {
            color: #ef4444;
        }

        .tx-status {
            font-size: 0.75rem;
            font-weight: 600;
            padding: 2px 8px;
            border-radius: 4px;
            display: inline-block;
            text-transform: capitalize;
        }

        .tx-status.success {
            background: #f0fdf4;
            color: #15803d;
        }

        .tx-status.pending {
            background: #fffbeb;
            color: #b45309;
        }

        .tx-status.failed {
            background: #fef2f2;
            color: #b91c1c;
        }

        .pagination {
            display: flex;
            justify-content: center;
            gap: 0.5rem;
            margin-top: 2rem;
        }
        
        .pagination .btn {
            padding: 0.5rem 1rem;
            border: 1px solid #e2e8f0;
            background: var(--white);
            border-radius: var(--radius-sm);
            cursor: pointer;
        }
        
        .pagination .btn.active {
            background: var(--primary);
            color: var(--white);
            border-color: var(--primary);
        }
        
        .empty-state {
            text-align: center;
            padding: 4rem 2rem;
            background: var(--white);
            border: 1px solid #e2e8f0;
            border-radius: var(--radius-lg);
        }
        
        .empty-state p {
            color: var(--text-muted, #94a3b8);
            font-size: 1.1rem;
        }
    </style>
</head>

<body>
    <!-- Header -->
    <%- include('../partials/header.ejs')%>

    <main>
        <div class="transactions-page-wrapper">
            <div class="page-header">
                <h2>Transaction History</h2>
                <a href="/user/wallet" class="back-btn">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="19" y1="12" x2="5" y2="12"></line>
                        <polyline points="12 19 5 12 12 5"></polyline>
                    </svg>
                    Back to Wallet
                </a>
            </div>

            <div class="transaction-list">
                <% if (wallet && wallet.transactions && wallet.transactions.length > 0) { %>
                    <% wallet.transactions.sort((a,b)=> new Date(b.createdAt) - new Date(a.createdAt)).forEach(tx => {
                        const isCredit = tx.type === 'credit';
                        const absAmount = Math.abs(tx.amount).toFixed(2);
                        %>
                        <div class="transaction-card">
                            <div class="tx-left">
                                <div class="tx-icon <%= isCredit ? 'credit' : 'debit' %>">
                                    <% if (isCredit) { %>
                                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
                                            stroke="currentColor" stroke-width="2.5">
                                            <polyline points="20 6 9 17 4 12"></polyline>
                                        </svg>
                                        <% } else { %>
                                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
                                                stroke="currentColor" stroke-width="2.5">
                                                <line x1="5" y1="12" x2="19" y2="12"></line>
                                            </svg>
                                            <% } %>
                                </div>
                                <div class="tx-details">
                                    <h4>
                                        <%= tx.description %>
                                    </h4>
                                    <div class="tx-date">
                                        <%= new Date(tx.createdAt).toLocaleDateString('en-US', {
                                            month: 'short' , day: 'numeric' , year: 'numeric' ,
                                            hour: 'numeric' , minute: '2-digit' }) %>
                                    </div>
                                </div>
                            </div>
                            <div class="tx-right">
                                <div class="tx-amount <%= isCredit ? 'credit' : 'debit' %>">
                                    <%= isCredit ? '+' : '-' %> ₹<%= absAmount %>
                                </div>
                                <div class="tx-status <%= tx.status %>">
                                    <%= tx.status.charAt(0).toUpperCase() + tx.status.slice(1) %>
                                </div>
                            </div>
                        </div>
                        <% }) %>
                <% } else { %>
                    <div class="empty-state">
                        <p>No transactions found.</p>
                    </div>
                <% } %>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <%- include('../partials/footer') %>

</body>
</html>
