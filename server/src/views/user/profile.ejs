<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Profile - logiaFun</title>
  <link rel="stylesheet" href="/css/home.css" />
  <link rel="stylesheet" href="/css/profile.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css" />
</head>

<body>
  <!-- Header -->
  <%- include('../partials/header.ejs')%>

    <main>
      <%- include('../partials/account-topbar.ejs') %>

      <div class="account-layout profile-container profile-page">
        <%- include('../partials/account-sidebar.ejs', { user, activePage: 'profile', allowProfileImageEdit: true }) %>

        <!-- Main Content -->
        <section class="account-content profile-content">
          <div class="account-card">
          <div class="profile-header">
            <h2>My Profile</h2>
            <button class="btn btn-secondary" id="editInfoButton">
              Edit Information
            </button>
          </div>

          <form class="profile-form" action="/user/profile" method="POST" novalidate>
            <fieldset id="profileFieldset" disabled>
              <div class="form-row">
                <div class="form-group">
                  <label>Name</label>
                  <input type="text" value="<%=user.name%>" name="name" required minlength="3" />
                </div>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label>Email Address</label>
                  <div class="input-with-button">
                    <input type="email" value="<%=user.email%>" name="email" />
                    <%if(!isGoogle){ %>
                      <button type="button" class="btn btn-sm btn-outline" id="changeEmailBtn" disabled>
                        Change
                      </button>
                      <%} %>
                  </div>
                </div>
                <div class="form-group">
                  <label>Phone Number</label>
                  <input type="tel" placeholder="" value="<%= user.phone || '' %>" name="phone" required
                    pattern="^[0-9]{10}$" data-msg-pattern="Please enter a valid 10-digit phone number" />
                </div>
              </div>

              <%if(!isGoogle){ %>
                <div class="form-row">
                  <div class="form-group" style="max-width: 50%">
                    <label>Password</label>
                    <div class="input-with-button">
                      <button type="button" class="btn btn-sm btn-outline open-password-modal" disabled
                        id="changePasswordBtn">
                        Change password
                      </button>

                    </div>
                  </div>
                </div>
                <%} %>


                  <button type="submit" class="btn btn-primary btn-save">
                    Save Changes
                  </button>
            </fieldset>
          </form>
          </div>
        </section>
      </div>
    </main>

    <div class="modal-overlay" id="emailModal">
      <div class="modal-content">
        <button class="modal-close" id="closeEmailModal" type="button">&times;</button>
        <div id="emailStep1">
          <h3>Change Email Address</h3>
          <p style="color: var(--text-muted); margin-bottom: 1.5rem">
            Enter your new email address. We'll send a verification code.
          </p>
          <div class="form-group">
            <label>New Email Address</label>
            <input type="email" id="newEmailInput" placeholder="name@example.com" />
          </div>
          <button class="btn btn-primary" style="width: 100%" id="sendOtpBtn">
            Proceed
          </button>
        </div>

        <div id="emailStep2" style="display: none">
          <h3>Verify Email</h3>
          <p style="color: var(--text-muted); margin-bottom: 1.5rem">
            Enter the 6-digit code sent to
            <strong id="displayNewEmail"></strong>
          </p>
          <div class="form-group">
            <label>Verification Code</label>
            <div class="otp-input-container">
              <input type="text" maxlength="1" class="otp-digit" />
              <input type="text" maxlength="1" class="otp-digit" />
              <input type="text" maxlength="1" class="otp-digit" />
              <input type="text" maxlength="1" class="otp-digit" />
              <input type="text" maxlength="1" class="otp-digit" />
              <input type="text" maxlength="1" class="otp-digit" />
            </div>
          </div>
          <button class="btn btn-primary" style="width: 100%" id="verifyOtpBtn">
            Verify & Update
          </button>
          <button class="btn btn-link" id="resendOtpBtn">Resend code</button>
          <button class="btn btn-link" style="width: 100%; margin-top: 1rem" id="backToEmailBtn">
            Back to Email
          </button>
        </div>

      </div>
    </div>

    <!-- Password Change Modal -->
    <div class="modal-overlay" id="passwordModal">
      <div class="modal-content">
        <button class="modal-close" id="closePasswordModal" type="button">&times;</button>

        <h3>Change Password</h3>
        <p style="color: var(--text-muted); margin-bottom: 1.5rem">
          Create a password for your account to enable email login
        </p>

        <form id="passwordChangeForm" novalidate>
          <div class="form-group">

            <label>Current Password</label>
            <div class="input-with-icon">
              <input type="password" name="currentPassword" placeholder="••••••••" required />
              <button type="button" class="password-toggle">
                <i class="fa-solid fa-eye-slash"></i>
              </button>
            </div>
          </div>

          <div class="form-group">
            <label>New Password</label>
            <div class="input-with-icon">
              <input type="password" id="newPassword" name="newPassword" placeholder="Min 8 characters" required
                minlength="8" />
              <button type="button" class="password-toggle">
                <i class="fa-solid fa-eye-slash"></i>
              </button>
            </div>
          </div>

          <div class="form-group">
            <label>Confirm New Password</label>
            <div class="input-with-icon">
              <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Confirm new password"
                required data-match="newPassword" />
              <button type="button" class="password-toggle">
                <i class="fa-solid fa-eye-slash"></i>
              </button>
            </div>
          </div>

          <small id="modalPasswordError" style="color: red; display: block; margin-bottom: 1rem"></small>

          <button type="submit" class="btn btn-primary" style="width: 100%">
            Update Password
          </button>
        </form>
      </div>
    </div>

    <!-- Footer -->
    <%- include('../partials/footer') %>
      <!-- Cropper Modal -->
      <div class="modal-overlay" id="cropperModal">
        <div class="modal-content" style="max-width: 600px; width: 95%;">
          <button class="modal-close" id="closeCropperModal" type="button">&times;</button>
          <h3>Crop Image</h3>
          <div class="img-container" style="max-height: 400px; overflow: hidden; margin-bottom: 20px;">
            <img id="imageToCrop" src="" alt="Picture to crop" style="max-width: 100%;">
          </div>
          <div style="display: flex; gap: 10px; justify-content: flex-end;">
            <button class="btn btn-outline" id="cancelCropBtn" type="button">Cancel</button>
            <button class="btn btn-primary" id="cropImageBtn" type="button">Done</button>
          </div>
        </div>
      </div>

      <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>
      <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
      <script src="/js/helpers/formValidator.js"></script>
      <script src="/js/user-profile.js"></script>
</body>

</html>
