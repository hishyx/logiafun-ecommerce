<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Orders - logiaFun</title>
  <link rel="stylesheet" href="/css/home.css" />
  <link rel="stylesheet" href="/css/profile.css" />
  <style>
    .orders-header {
      margin-bottom: 2.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .orders-title {
      font-family: "Fredoka", sans-serif;
      font-size: 2.5rem;
      color: var(--primary);
      margin: 0;
    }

    .order-tabs {
      display: flex;
      gap: 0.5rem;
      background: #f1f5f9;
      padding: 0.4rem;
      border-radius: 12px;
      width: fit-content;
    }

    .order-tab {
      padding: 0.6rem 1.2rem;
      border-radius: 8px;
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--text-light);
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .order-tab.active {
      background: var(--white);
      color: var(--primary);
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }

    .order-list {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .order-card {
      background: var(--white);
      border-radius: 16px;
      border: 1px solid #f1f5f9;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
      overflow: hidden;
      transition: all 0.3s ease;
    }

    .order-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
      border-color: #e2e8f0;
    }

    .order-card-header {
      padding: 1.25rem 1.5rem;
      background: #fcfdfe;
      border-bottom: 1px solid #f1f5f9;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .order-meta {
      display: flex;
      gap: 2rem;
      flex-wrap: wrap;
    }

    .meta-item {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .meta-label {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--text-muted);
      font-weight: 600;
    }

    .meta-value {
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--primary);
    }

    .status-badge {
      padding: 0.4rem 1rem;
      border-radius: 50px;
      font-size: 0.85rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }

    /* Pending */
    .status-pending {
      background: #fef9c3;
      color: #ca8a04;
    }

    /* Processing */
    .status-processing {
      background: #fff7ed;
      color: #d97706;
    }

    /* In Transit */
    .status-in_transit {
      background: #eff6ff;
      color: #2563eb;
    }

    /* Delivered */
    .status-delivered {
      background: #ecfdf5;
      color: #059669;
    }

    /* Cancelled */
    .status-cancelled {
      background: #fef2f2;
      color: #dc2626;
    }

    /* Returned */
    .status-returned {
      background: #f5f3ff;
      color: #7c3aed;
    }

    .status-cancelled {
      background: #fef2f2;
      color: #dc2626;
    }

    .status-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: currentColor;
    }

    .order-content {
      padding: 1.5rem;
    }

    .order-item-row {
      display: flex;
      gap: 1.5rem;
      align-items: center;
    }

    .order-item-img {
      width: 90px;
      height: 90px;
      border-radius: 12px;
      object-fit: cover;
      background: #f8fafc;
      border: 1px solid #f1f5f9;
    }

    .order-item-info {
      flex: 1;
    }

    .order-item-name {
      font-family: "Fredoka", sans-serif;
      font-size: 1.1rem;
      color: var(--primary);
      margin-bottom: 0.4rem;
      display: block;
    }

    .order-item-desc {
      font-size: 0.85rem;
      color: var(--text-light);
      display: -webkit-box;
      -webkit-line-clamp: 2;
      line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      margin-bottom: 0.75rem;
      line-height: 1.4;
      max-width: 500px;
    }

    .order-item-price {
      font-weight: 700;
      color: var(--text-dark);
      font-size: 1.05rem;
    }

    .order-card-footer {
      padding: 1.25rem 1.5rem;
      background: #ffffff;
      border-top: 1px solid #f1f5f9;
      display: flex;
      justify-content: flex-end;
      gap: 1rem;
    }

    .order-btn {
      padding: 0.6rem 1.2rem;
      border-radius: 10px;
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease;
      text-align: center;
    }

    .btn-outline {
      background: transparent;
      border: 1.5px solid #e2e8f0;
      color: var(--text-light);
    }

    .btn-outline:hover {
      border-color: var(--primary);
      color: var(--primary);
      background: #f8fafc;
    }

    .btn-fill {
      background: var(--primary);
      color: var(--white);
      border: none;
    }

    .btn-fill:hover {
      background: var(--primary-dark);
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(30, 58, 95, 0.2);
    }

    .view-order-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.65rem;
      min-width: 170px;
      padding: 0.85rem 1.25rem;
      border-radius: 14px;
      text-decoration: none;
      background: linear-gradient(135deg, #1e3a5f 0%, #294a76 100%);
      color: #fff;
      box-shadow: 0 12px 24px rgba(30, 58, 95, 0.18);
      border: 1px solid rgba(30, 58, 95, 0.15);
    }

    .view-order-btn svg {
      width: 17px;
      height: 17px;
      transition: transform 0.2s ease;
    }

    .view-order-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 16px 28px rgba(30, 58, 95, 0.24);
      background: #ffffff;
      color: #1e3a5f;
      border-color: rgba(30, 58, 95, 0.25);
    }

    .view-order-btn:hover svg {
      transform: translateX(3px);
    }

    @media (max-width: 600px) {
      .orders-header {
        flex-direction: column;
        align-items: flex-start;
      }

      .order-tabs {
        width: 100%;
        overflow-x: auto;
      }

      .order-meta {
        gap: 1rem;
      }

      .order-item-row {
        flex-direction: column;
        align-items: flex-start;
        gap: 1rem;
      }

      .order-item-img {
        width: 100%;
        height: 200px;
      }

      .view-order-btn {
        width: 100%;
        min-width: 0;
      }
    }

    /* Empty Orders Styles */
    .empty-orders-section {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 5rem 2rem;
      text-align: center;
      background: #fff;
      border-radius: 16px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
      border: 1px solid #f1f5f9;
      margin: 1rem 0;
      animation: fadeIn 0.5s ease-out;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(10px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .empty-orders-icon {
      width: 120px;
      height: 120px;
      background: #f8fafc;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 2rem;
      color: #94a3b8;
      position: relative;
    }

    .empty-orders-icon::after {
      content: '';
      position: absolute;
      width: 140px;
      height: 140px;
      border: 2px dashed #e2e8f0;
      border-radius: 50%;
      animation: rotate 20s linear infinite;
    }

    @keyframes rotate {
      from {
        transform: rotate(0deg);
      }

      to {
        transform: rotate(360deg);
      }
    }

    .empty-orders-section h2 {
      font-family: "Fredoka", sans-serif;
      font-size: 1.75rem;
      color: var(--primary);
      margin-bottom: 0.75rem;
    }

    .empty-orders-section p {
      color: var(--text-light);
      font-size: 1rem;
      max-width: 350px;
      margin-bottom: 2.5rem;
      line-height: 1.5;
    }

    .explore-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      padding: 1rem 2.5rem;
      text-decoration: none;
    }
  </style>
</head>

<body>
  <!-- Header -->
  <%- include('../partials/header.ejs')%>

    <main>
      <%- include('../partials/account-topbar.ejs') %>

      <div class="account-layout profile-container orders-page">
        <%- include('../partials/account-sidebar.ejs', { user, activePage: 'orders', allowProfileImageEdit: false }) %>

        <!-- Main Content -->
        <section class="account-content profile-content">
          <div class="account-card">
          <div class="orders-header">
            <h1 class="orders-title">My Orders</h1>
            <a href="/user/orders/list" class="order-btn btn-outline" style="text-decoration: none;">View All Orders</a>
          </div>

          <% if (orders && orders.length> 0) { %>
            <div class="order-list">
              <% orders.forEach(order=> { %>
                <div class="order-card">
                  <div class="order-card-header">
                    <div class="order-meta">
                      <div class="meta-item">
                        <span class="meta-label">Order Placed</span>
                        <span class="meta-value">
                          <%= new Date(order.createdAt).toLocaleDateString("en-US", {month: "short" , day: "numeric" ,
                            year: "numeric" }) %>
                        </span>
                      </div>
                      <div class="meta-item">
                        <span class="meta-label">Total Amount</span>
                        <span class="meta-value">₹<%= order.payment.amount %></span>
                      </div>
                      <div class="meta-item">
                        <span class="meta-label">Order #</span>
                        <span class="meta-value">
                          <%= order.orderNumber %>
                        </span>
                      </div>
                      <div class="meta-item">
                        <span class="meta-label">Items</span>
                        <span class="meta-value">
                          <%= order.items.length %>
                        </span>
                      </div>
                      <div class="meta-item">
                        <span class="meta-label">Payment Status</span>
                        <span class="meta-value">
                          <span class="status-badge <%= order.payment && order.payment.status === 'paid' ? 'status-delivered' : 'status-cancelled' %>" style="padding: 0.2rem 0.75rem; border-radius: 50px; font-size: 0.75rem; display: inline-flex;">
                            <%= order.payment && order.payment.status === 'paid' ? 'Paid' : 'Non-Paid' %>
                          </span>
                        </span>
                      </div>
                    </div>
                    <div class="status-badge status-<%= order.orderStatus %>">
                      <span class="status-dot"></span>
                      <%= order.orderStatus.charAt(0).toUpperCase() + order.orderStatus.slice(1) %>
                    </div>
                  </div>
                  <div class="order-content">
                    <div style="display: flex; align-items: center; gap: 0.75rem;">
                      <% order.items.slice(0, 3).forEach(item=> { %>
                        <div
                          style="width: 50px; height: 50px; border-radius: 8px; overflow: hidden; border: 1px solid #f1f5f9; background: #f8fafc; flex-shrink: 0;">
                          <img src="<%= item.product.image %>" alt="<%= item.product.name %>"
                            style="width: 100%; height: 100%; object-fit: cover;">
                        </div>
                        <% }) %>

                          <% if (order.items.length> 3) { %>
                            <div
                              style="height: 50px; padding: 0 0.75rem; border-radius: 8px; border: 1px solid #f1f5f9; background: #f8fafc; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; font-weight: 700; color: var(--text-light); flex-shrink: 0;">
                              +<%= order.items.length - 3 %> more
                            </div>
                            <% } %>
                    </div>

                    <div class="order-card-footer"
                      style="padding: 1rem 0 0 0; margin-top: 1rem; border-top: 1px solid #f1f5f9;">
                      <a href="/user/orders/<%= order._id %>" class="order-btn btn-fill view-order-btn">
                        View Details
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <line x1="5" y1="12" x2="19" y2="12"></line>
                          <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                      </a>
                    </div>
                  </div>
                </div>
                <% }) %>
            </div>
            <% } else { %>
              <div class="empty-orders-section">
                <div class="empty-orders-icon">
                  <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                    <line x1="8" y1="21" x2="16" y2="21"></line>
                    <line x1="12" y1="17" x2="12" y2="21"></line>
                  </svg>
                </div>
                <h2>No orders yet!</h2>
                <p>Looks like you haven't placed any orders yet. Start shopping to see your orders here.</p>
                <a href="/products" class="order-btn btn-fill explore-btn">
                  Explore Products
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                  </svg>
                </a>
              </div>

              <% } %>
          </div>
        </section>
      </div>
    </main>

    <!-- Footer -->
    <%- include('../partials/footer') %>

      <script>
        // No tabs logic needed here anymore as this is just a quick view.
      </script>
</body>

</html>
