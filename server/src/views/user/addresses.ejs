<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Addresses - logiaFun</title>
  <link rel="stylesheet" href="/css/home.css" />
  <link rel="stylesheet" href="/css/profile.css" />
</head>

<body>
  <!-- Header -->
  <%- include('../partials/header.ejs')%>

    <main>
      <%- include('../partials/account-topbar.ejs') %>

      <div class="account-layout profile-container addresses-page">
        <%- include('../partials/account-sidebar.ejs', { user, activePage: 'addresses', allowProfileImageEdit: false }) %>

        <!-- Main Content -->
        <section class="account-content profile-content">
          <div class="account-card">
          <div class="profile-header">
            <h2>My Addresses</h2>
            <button class="btn btn-secondary">Add New Address</button>
          </div>

          <div class="addresses-grid">
            <!-- Add New Card -->
            <div class="add-address-card">
              <div class="add-icon-circle">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="12" y1="5" x2="12" y2="19"></line>
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
              </div>

              <span class="add-address-text">
                <%= addresses && addresses.length ? "Add Address" : "Add Your First Address" %>
              </span>
            </div>

            <% if (addresses && addresses.length) { %>

              <% addresses.forEach(address=> { %>

                <div class="address-card <%= address.isDefault ? 'default' : '' %>" data-id="<%= address._id %>">


                  <% if (address.isDefault) { %>
                    <span class="address-type-badge">
                      <%= address.addressName %>(Default)
                    </span>
                    <% } else { %>
                      <span class="address-type-badge">
                        <%= address.addressName %>
                      </span>
                      <% } %>

                        <div class="address-details">


                          <!-- person name -->
                          <span class="address-name">
                            <%= address.name %>
                          </span><br>

                          <span class="address-street">
                            <%= address.street %>
                          </span><br>

                          <span class="address-city">
                            <%= address.city %>
                          </span> -
                          <span class="address-pincode">
                            <%= address.pincode %>
                          </span><br>

                          Phone:
                          <span class="address-phone">
                            <%= address.phone %>
                          </span>
                        </div>



                        <div class="address-actions">
                          <button class="btn-link edit-btn" data-id="<%= address._id %>">
                            Edit
                          </button>

                          <% if (!address.isDefault) { %>
                            <button class="btn-link default-btn" data-id="<%= address._id %>">
                              Set as Default
                            </button>

                            <button class="btn-link delete-btn" data-id="<%= address._id %>">
                              Delete
                            </button>
                            <% } %>
                        </div>


                </div>

                <% }) %>


                  <% } %>


          </div> <!-- addresses-grid -->
          </div>
          </div>
        </section> <!-- profile-content -->
      </div> <!-- profile-container -->
    </main>


    <!-- Footer -->
    <%- include('../partials/footer') %>
      <!-- Add Address Modal -->
      <div class="modal-overlay" id="addAddressModal">
        <div class="modal-content">
          <button class="modal-close" id="closeAddModal">&times;</button>
          <h3>Add New Address</h3>
          <form class="profile-form" id="addAddressForm" novalidate>
            <div class="form-group">
              <label>Address Name (e.g., Home, Office)</label>
              <input type="text" placeholder="Home" name="addressName" required minlength="3" />
            </div>
            <div class="form-group">
              <label>Full Name</label>
              <input type="text" placeholder="John Doe" name="name" required minlength="3" />
            </div>
            <div class="form-group">
              <label>Street Address</label>
              <input type="text" placeholder="123 Street Name" name="street" required />
            </div>
            <div class="form-row">
              <div class="form-group">
                <label>City</label>
                <input type="text" placeholder="City" name="city" required />
              </div>
              <div class="form-group">
                <label>State/Zip</label>
                <input type="text" placeholder="Pincode" name="pincode" required pattern="^[0-9]{6}$"
                  data-msg-pattern="Please enter a valid 6-digit pincode" />
              </div>
            </div>
            <div class="form-group">
              <label>Phone Number</label>
              <input type="tel" placeholder="10-digit number" name="phone" required pattern="^[0-9]{10}$"
                data-msg-pattern="Please enter a valid 10-digit phone number" />
            </div>
            <button type="submit" class="btn btn-primary btn-save" style="width: 100%">
              Save Address
            </button>
          </form>
        </div>
      </div>

      <!-- Edit Address Modal -->
      <div class="modal-overlay" id="editAddressModal">
        <div class="modal-content">
          <button class="modal-close" id="closeEditModal">&times;</button>
          <h3>Edit Address</h3>
          <form class="profile-form" id="editAddressForm" novalidate>
            <div class="form-group">
              <label>Address Name (e.g., Home, Office)</label>
              <input type="text" name="addressName" required minlength="3" />
            </div>
            <div class="form-group">
              <label>Full Name</label>
              <input type="text" name="name" required minlength="3" />
            </div>
            <div class="form-group">
              <label>Street Address</label>
              <input type="text" name="street" required />
            </div>
            <div class="form-row">
              <div class="form-group">
                <label>City</label>
                <input type="text" name="city" required />
              </div>
              <div class="form-group">
                <label>State/Zip</label>
                <input type="text" name="pincode" required pattern="^[0-9]{6}$"
                  data-msg-pattern="Please enter a valid 6-digit pincode" />
              </div>
            </div>
            <div class="form-group">
              <label>Phone Number</label>
              <input type="tel" name="phone" required pattern="^[0-9]{10}$"
                data-msg-pattern="Please enter a valid 10-digit phone number" />
            </div>
            <button type="submit" class="btn btn-primary btn-save" style="width: 100%">
              Update Address
            </button>
          </form>
        </div>
      </div>

      <!-- Delete Confirmation Modal -->
      <div class="modal-overlay" id="deleteConfirmationModal">
        <div class="modal-content" style="text-align: center">
          <button class="modal-close" id="closeDeleteModal">&times;</button>
          <div style="margin-bottom: 1rem; color: #ef4444">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 6h18"></path>
              <path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path>
              <path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path>
            </svg>
          </div>
          <h3 style="font-size: 1.25rem; margin-bottom: 0.5rem">
            Delete Address?
          </h3>
          <p style="color: var(--text-muted); margin-bottom: 2rem">
            Are you sure you want to delete this address? This action cannot be
            undone.
          </p>
          <div style="display: flex; gap: 1rem; justify-content: center">
            <button class="btn btn-outline" id="cancelDeleteBtn">Cancel</button>
            <button class="btn btn-primary" style="background-color: #ef4444; border-color: #ef4444"
              id="confirmDeleteBtn">
              Delete
            </button>
          </div>
        </div>
      </div>

      <!-- Set Default Confirmation Modal -->
      <div class="modal-overlay" id="defaultConfirmationModal">
        <div class="modal-content" style="text-align: center">
          <button class="modal-close" id="closeDefaultModal">&times;</button>
          <div style="margin-bottom: 1rem; color: var(--primary)">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
          </div>
          <h3 style="font-size: 1.25rem; margin-bottom: 0.5rem">
            Set as Default?
          </h3>
          <p style="color: var(--text-muted); margin-bottom: 2rem">
            Make this your primary shipping address for all future orders?
          </p>
          <div style="display: flex; gap: 1rem; justify-content: center">
            <button class="btn btn-outline" id="cancelDefaultBtn">Cancel</button>
            <button class="btn btn-primary" id="confirmDefaultBtn">


              Set as Default
            </button>
          </div>
        </div>
      </div>

      <script src="/js/helpers/formValidator.js"></script>
      <script src="/js/user-addresses.js"></script>
</body>

</html>
