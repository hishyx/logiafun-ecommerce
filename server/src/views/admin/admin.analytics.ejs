    // order status doughnut chart
    function buildStatusChart() {
      const canvas = document.getElementById("statusChart");
      if (!canvas) return;

      // STATUS_MAP comes from SSR (statusEntries array)
      const labels = STATUS_MAP.map(e => e[0]);
      const values = STATUS_MAP.map(e => e[1]);
      const palette = ["#3b82f6","#10b981","#f59e0b","#8b5cf6","#ef4444","#06b6d4","#ec4899"];

      new Chart(canvas.getContext("2d"), {
        type: "doughnut",
        data: {
          labels,
          datasets: [{
            data: values,
            backgroundColor: palette.slice(0, labels.length),
            borderWidth: 2,
            borderColor: "#fff",
            hoverOffset: 6,
          }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          cutout: "65%",
          animation: { duration: 700 },
          plugins: {
            legend: {
              position: "right",
              labels: {
                font: { size: 12, weight: "600" },
                color: "#334155",
                padding: 14,
                usePointStyle: true,
                pointStyleWidth: 10,
              },
            },
            tooltip: {
              backgroundColor: "rgba(15,23,42,0.92)",
              callbacks: {
                label: ctx => ` ${ctx.label}: ${ctx.parsed} orders`,
              },
            },
          },
        },
      });
    }

    // animate top-product progress bars (same rAF trick as dashboard)
    function animateBars() {
      document.querySelectorAll(".prog-fill[data-width]").forEach(el => {
        requestAnimationFrame(() => { el.style.width = el.dataset.width + "%"; });
      });
    }

    // mobile sidebar toggle
    const mobileToggle = document.querySelector(".mobile-toggle");
    if (mobileToggle) {
      mobileToggle.addEventListener("click", () => {
        document.querySelector(".sidebar").classList.toggle("active");
      });
    }

    document.addEventListener("DOMContentLoaded", () => {
      // buildTrendChart(); — commented out
      buildStatusChart();
      animateBars();
    });
  </script>
</body>
</html>
