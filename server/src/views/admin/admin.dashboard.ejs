<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard - LogiaFun</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <link rel="stylesheet" href="/css/admin/main.css" />
  <style>
    :root {
      --primary-dark: #0f172a;
      --accent-blue: #3b82f6;
      --accent-green: #10b981;
      --accent-purple: #8b5cf6;
      --accent-orange: #f59e0b;
      --glass-bg: rgba(255, 255, 255, 0.7);
      --glass-border: rgba(255, 255, 255, 0.2);
    }

    .dashboard-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1.5rem;
      margin-bottom: 2rem;
    }

    .stat-card {
      background: var(--glass-bg);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid var(--glass-border);
      border-radius: 20px;
      padding: 1.5rem;
      display: flex;
      align-items: center;
      gap: 1.25rem;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.05);
    }

    .stat-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 20px 40px -15px rgba(0, 0, 0, 0.1);
    }

    .stat-icon {
      width: 60px;
      height: 60px;
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      flex-shrink: 0;
    }

    .stat-info .label {
      font-size: 0.875rem;
      color: #64748b;
      font-weight: 500;
      margin-bottom: 0.25rem;
      display: block;
    }

    .stat-info .value {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--primary-dark);
    }

    /* Column Icons and Colors */
    .icon-revenue { background: #eff6ff; color: var(--accent-blue); }
    .icon-orders { background: #f0fdf4; color: var(--accent-green); }
    .icon-users { background: #f5f3ff; color: var(--accent-purple); }
    .icon-products { background: #fff7ed; color: var(--accent-orange); }

    .main-grid {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 1.5rem;
    }

    .chart-container {
      background: white;
      border-radius: 20px;
      padding: 1.5rem;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
      border: 1px solid #f1f5f9;
    }

    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1.5rem;
    }

    .section-title {
      font-size: 1.125rem;
      font-weight: 700;
      color: var(--primary-dark);
    }

    .view-all {
      font-size: 0.875rem;
      color: var(--accent-blue);
      text-decoration: none;
      font-weight: 600;
    }

    .recent-table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0 0.75rem;
    }

    .recent-table th {
      text-align: left;
      padding: 0.5rem 1rem;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #94a3b8;
      font-weight: 600;
    }

    .recent-table td {
      padding: 1rem;
      background: #f8fafc;
      font-size: 0.875rem;
      color: #334155;
    }

    .recent-table td:first-child {
      border-top-left-radius: 12px;
      border-bottom-left-radius: 12px;
    }

    .recent-table td:last-child {
      border-top-right-radius: 12px;
      border-bottom-right-radius: 12px;
    }

    .status-pill {
      padding: 0.25rem 0.75rem;
      border-radius: 20px;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: capitalize;
    }

    .status-paid { background: #dcfce7; color: #166534; }

    @media (max-width: 1024px) {
      .main-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>

<body>
  <div class="admin-container">
    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="logo-area">
        <h2>LogiaFun <span class="badge">Admin</span></h2>
      </div>

      <nav class="sidebar-nav">
        <ul>
          <li class="nav-item active">
            <a href="/admin/dashboard" class="nav-link">
              <i class="fa-solid fa-chart-line"></i>
              <span>Dashboard</span>
            </a>
          </li>
          <li class="nav-item">
            <a href="/admin/analytics" class="nav-link">
              <i class="fa-solid fa-chart-pie"></i>
              <span>Analytics</span>
            </a>
          </li>
          <li class="nav-item">
            <a href="/admin/products" class="nav-link">
              <i class="fa-solid fa-box"></i>
              <span>Products</span>
            </a>
          </li>
          <li class="nav-item">
            <a href="/admin/categories" class="nav-link">
              <i class="fa-solid fa-layer-group"></i>
              <span>Categories</span>
            </a>
          </li>
          <li class="nav-item">
            <a href="/admin/orders" class="nav-link">
              <i class="fa-solid fa-cart-shopping"></i>
              <span>Orders</span>
            </a>
          </li>
          <li class="nav-item">
            <a href="/admin/users" class="nav-link">
              <i class="fa-solid fa-users"></i>
              <span>Users</span>
            </a>
          </li>
          <li class="nav-item">
            <a href="/admin/coupons" class="nav-link">
              <i class="fa-solid fa-ticket"></i>
              <span>Coupons</span>
            </a>
          </li>
          <li class="nav-item">
            <a href="/admin/offers" class="nav-link">
              <i class="fa-solid fa-tags"></i>
              <span>Offers</span>
            </a>
          </li>
        </ul>
      </nav>
      <div class="sidebar-footer">
        <form action="/admin/logout" method="POST" class="logout-form">
          <button type="submit" class="nav-link logout logout-btn">
            <i class="fa-solid fa-right-from-bracket"></i>
            <span>Logout</span>
          </button>
        </form>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
      <header class="top-bar">
        <div class="mobile-toggle">
          <i class="fa-solid fa-bars"></i>
        </div>
        <div class="page-title">
          <h1>Dashboard Overview</h1>
        </div>
        <div class="user-profile">
          <div class="notification-icon">
            <i class="fa-regular fa-bell"></i>
            <span class="dot"></span>
          </div>
          <div class="profile-info">
            <img src="https://ui-avatars.com/api/?name=Admin+User&background=0D8ABC&color=fff" alt="Admin" />
            <span>Admin</span>
          </div>
        </div>
      </header>

      <div class="content-body">
        <!-- Stats Grid -->
        <div class="dashboard-grid">
          <div class="stat-card">
            <div class="stat-icon icon-revenue">
              <i class="fa-solid fa-indian-rupee-sign"></i>
            </div>
            <div class="stat-info">
              <span class="label">Total Revenue</span>
              <span class="value">₹<%= totalRevenue.toLocaleString() %></span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon icon-orders">
              <i class="fa-solid fa-cart-shopping"></i>
            </div>
            <div class="stat-info">
              <span class="label">Orders</span>
              <span class="value"><%= totalOrders %></span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon icon-users">
              <i class="fa-solid fa-users"></i>
            </div>
            <div class="stat-info">
              <span class="label">Customers</span>
              <span class="value"><%= totalUsers %></span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon icon-products">
              <i class="fa-solid fa-box"></i>
            </div>
            <div class="stat-info">
              <span class="label">Total Products</span>
              <span class="value"><%= totalProducts %></span>
            </div>
          </div>
        </div>

        <div class="main-grid">
          <!-- Sales Chart -->
          <div class="chart-container">
            <div class="section-header">
              <h2 class="section-title">Sales Revenue (Last 7 Days)</h2>
            </div>
            <canvas id="salesChart" height="150"></canvas>
          </div>

          <!-- Recent Orders -->
          <div class="chart-container">
            <div class="section-header">
              <h2 class="section-title">Recent Orders</h2>
              <a href="/admin/orders" class="view-all">View All</a>
            </div>
            <table class="recent-table">
              <thead>
                <tr>
                  <th>Order</th>
                  <th>Amount</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% recentOrders.forEach(order => { %>
                  <tr>
                    <td>#<%= order.orderNumber %></td>
                    <td>₹<%= order.payment.amount %></td>
                    <td><span class="status-pill status-paid">Paid</span></td>
                  </tr>
                <% }) %>
                <% if (recentOrders.length === 0) { %>
                  <tr><td colspan="3" style="text-align: center;">No recent orders</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    const ctx = document.getElementById('salesChart').getContext('2d');
    const labels = <%- chartLabels %>;
    const values = <%- chartValues %>;

    new Chart(ctx, {
      type: 'line',
      data: {
        labels: labels,
        datasets: [{
          label: 'Revenue',
          data: values,
          borderColor: '#3b82f6',
          backgroundColor: 'rgba(59, 130, 246, 0.1)',
          borderWidth: 3,
          fill: true,
          tension: 0.4,
          pointBackgroundColor: '#3b82f6',
          pointBorderColor: '#fff',
          pointBorderWidth: 2,
          pointRadius: 5,
          pointHoverRadius: 7
        }]
      },
      options: {
        responsive: true,
        plugins: {
          legend: { display: false }
        },
        scales: {
          y: {
            beginAtZero: true,
            grid: { color: '#f1f5f9' },
            ticks: {
              callback: function(value) { return '₹' + value; }
            }
          },
          x: {
            grid: { display: false }
          }
        }
      }
    });
  </script>
</body>

</html>
